# Doc-Sorter Umgebungsvariablen — Vorlage
# Kopiere diese Datei zu .env und trage deine Werte ein.
# .env wird NICHT in Git eingecheckt.

# Supabase (Firmen-Backend fuer E-Mail-Profile)
SUPABASE_URL=https://<dein-projekt>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_<dein-anon-key>

# Optional: KI-Anbieter (alternativ in config.yaml > llm)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
